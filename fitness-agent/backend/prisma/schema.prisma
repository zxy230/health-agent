generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String                   @id @default(cuid())
  name              String                   @default("")
  email             String                   @unique
  passwordHash      String
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  healthProfile     HealthProfile?
  bodyMetricLogs    BodyMetricLog[]
  dailyCheckins     DailyCheckin[]
  workoutLogs       WorkoutLog[]
  workoutPlans      WorkoutPlan[]
  dietRecommendations DietRecommendationSnapshot[]
  adviceSnapshots   AdviceSnapshot[]
  agentThreads      AgentThread[]
  coachingReviewSnapshots CoachingReviewSnapshot[]
  coachingMemories UserCoachingMemory[]
  coachingMemoryEvents CoachingMemoryEvent[]
  coachingOutcomes CoachingOutcome[]
  recommendationFeedbacks RecommendationFeedback[]
  agentActionProposals AgentActionProposal[]
  agentActionExecutions AgentActionExecution[]
  agentProposalGroups AgentProposalGroup[]
}

model HealthProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  age                 Int?
  gender              String?
  heightCm            Float?
  currentWeightKg     Float?
  targetWeightKg      Float?
  activityLevel       String?
  trainingExperience  String?
  trainingDaysPerWeek Int?
  equipmentAccess     String?
  limitations         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BodyMetricLog {
  id          String   @id @default(cuid())
  userId      String
  weightKg    Float
  bodyFatPct  Float?
  waistCm     Float?
  recordedAt  DateTime @default(now())
  source      String   @default("manual")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyCheckin {
  id           String   @id @default(cuid())
  userId       String
  sleepHours   Float
  waterMl      Int
  steps        Int
  energyLevel  String?
  fatigueLevel String?
  hungerLevel  String?
  recordedAt   DateTime @default(now())
  source       String   @default("manual")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkoutLog {
  id           String   @id @default(cuid())
  userId       String
  workoutType  String
  durationMin  Int
  intensity    String
  exerciseNote String?
  completion   String?
  painFeedback String?
  fatigueAfter String?
  recordedAt   DateTime @default(now())
  source       String   @default("manual")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkoutPlan {
  id          String           @id @default(cuid())
  userId      String
  title       String
  goal        String
  weekOf      DateTime
  version     Int              @default(1)
  status      String           @default("active")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  days        WorkoutPlanDay[]
}

model WorkoutPlanDay {
  id            String      @id @default(cuid())
  workoutPlanId String
  dayLabel      String
  focus         String
  duration      String
  exercises     Json
  recoveryTip   String
  isCompleted   Boolean     @default(false)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
}

model DietRecommendationSnapshot {
  id               String   @id @default(cuid())
  userId           String
  date             DateTime
  userGoal         String
  totalCalorie     Int
  targetCalorie    Int
  nutritionRatio   Json
  nutritionDetail  Json
  meals            Json
  agentTips        String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Exercise {
  id              String            @id
  name            String
  targetMuscles   String[]
  equipment       String
  level           String
  steps           String[]
  commonMistakes  String[]
  contraindicates String[]
  recoveryNotes   String[]
  variants        ExerciseVariant[]
}

model ExerciseVariant {
  id          String   @id @default(cuid())
  exerciseId  String
  title       String
  description String
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

model TrainingTemplate {
  id          String   @id
  name        String
  splitType   String
  level       String
  description String
  daysPerWeek Int
}

model AdviceSnapshot {
  id               String   @id @default(cuid())
  userId           String
  type             String
  priority         String
  summary          String
  reasoningTags    String[]
  actionItems      String[]
  riskFlags        String[]
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoachingReviewSnapshot {
  id                 String               @id @default(cuid())
  userId             String
  threadId           String
  runId              String?
  type               String
  status             String               @default("draft")
  periodStart        DateTime?
  periodEnd          DateTime?
  title              String
  summary            String
  adherenceScore     Int?
  riskFlags          String[]
  focusAreas         String[]
  recommendationTags String[]
  inputSnapshot      Json
  resultSnapshot     Json
  strategyTemplateId String?
  strategyVersion    String?
  evidence           Json?
  uncertaintyFlags   String[]             @default([])
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread             AgentThread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  run                AgentRun?            @relation(fields: [runId], references: [id], onDelete: SetNull)
  proposalGroups     AgentProposalGroup[]
  coachingOutcomes   CoachingOutcome[]
  recommendationFeedbacks RecommendationFeedback[]

  @@index([userId, type, createdAt])
  @@index([threadId, createdAt])
}

model CoachingOutcome {
  id                 String                 @id @default(cuid())
  userId             String
  reviewSnapshotId   String?
  proposalGroupId    String?                @unique
  strategyTemplateId String?
  strategyVersion    String?
  status             String                 @default("pending")
  measurementStart   DateTime
  measurementEnd     DateTime
  baseline           Json
  observed           Json
  score              Int?
  signals            Json
  summary            String
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewSnapshot     CoachingReviewSnapshot? @relation(fields: [reviewSnapshotId], references: [id], onDelete: SetNull)
  proposalGroup      AgentProposalGroup?    @relation(fields: [proposalGroupId], references: [id], onDelete: SetNull)

  @@index([userId, status, updatedAt])
  @@index([reviewSnapshotId, createdAt])
}

model RecommendationFeedback {
  id               String                  @id @default(cuid())
  userId           String
  reviewSnapshotId String?
  proposalGroupId  String?
  feedbackType     String
  note             String?
  createdAt        DateTime                @default(now())
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewSnapshot   CoachingReviewSnapshot? @relation(fields: [reviewSnapshotId], references: [id], onDelete: SetNull)
  proposalGroup    AgentProposalGroup?     @relation(fields: [proposalGroupId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([reviewSnapshotId, createdAt])
  @@index([proposalGroupId, createdAt])
}

model CoachingStrategyTemplate {
  id           String   @id @default(cuid())
  key          String
  version      String
  title        String
  description  String
  triggerRules Json
  riskPolicy   String
  outputShape  Json
  status       String   @default("draft")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([key, version])
  @@index([status, key])
}

model UserCoachingMemory {
  id           String                @id @default(cuid())
  userId       String
  memoryType   String
  title        String
  summary      String
  value        Json
  confidence   Int                   @default(60)
  sourceType   String
  sourceId     String?
  status       String                @default("active")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  events       CoachingMemoryEvent[]

  @@index([userId, status, updatedAt])
  @@index([userId, memoryType, status])
}

model CoachingMemoryEvent {
  id         String              @id @default(cuid())
  userId     String
  memoryId   String?
  eventType  String
  reason     String
  before     Json?
  after      Json?
  sourceType String
  sourceId   String?
  createdAt  DateTime            @default(now())
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  memory     UserCoachingMemory? @relation(fields: [memoryId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([memoryId, createdAt])
}

model AgentThread {
  id          String         @id @default(cuid())
  userId      String
  title       String
  summary     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    AgentMessage[]
  runs        AgentRun[]
  proposals   AgentActionProposal[]
  coachingReviews CoachingReviewSnapshot[]
  proposalGroups AgentProposalGroup[]
}

model AgentMessage {
  id             String      @id @default(cuid())
  threadId       String
  role           String
  content        String
  reasoning      String?
  cards          Json?
  createdAt      DateTime    @default(now())
  thread         AgentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model AgentRun {
  id          String         @id @default(cuid())
  threadId    String
  status      String
  riskLevel   String
  createdAt   DateTime       @default(now())
  thread      AgentThread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  steps       AgentRunStep[]
  proposals   AgentActionProposal[]
  coachingReviews CoachingReviewSnapshot[]
  proposalGroups AgentProposalGroup[]
}

model AgentRunStep {
  id          String   @id @default(cuid())
  runId       String
  stepType    String
  title       String
  payload     Json
  createdAt   DateTime @default(now())
  run         AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model AgentActionProposal {
  id                  String                @id @default(cuid())
  threadId            String
  runId               String
  userId              String
  proposalGroupId     String?
  status              String                @default("pending")
  actionType          String
  entityType          String
  entityId            String?
  title               String
  summary             String
  payload             Json
  preview             Json
  riskLevel           String
  requiresConfirmation Boolean             @default(true)
  expiresAt           DateTime?
  executedAt          DateTime?
  basePlanId          String?
  basePlanVersion     Int?
  basePlanUpdatedAt   DateTime?
  expectedDayId       String?
  expectedDayUpdatedAt DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  thread              AgentThread           @relation(fields: [threadId], references: [id], onDelete: Cascade)
  run                 AgentRun              @relation(fields: [runId], references: [id], onDelete: Cascade)
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposalGroup       AgentProposalGroup?   @relation(fields: [proposalGroupId], references: [id], onDelete: SetNull)
  executions          AgentActionExecution[]

  @@index([threadId, status, createdAt])
  @@index([runId, createdAt])
  @@index([userId, status, createdAt])
  @@index([proposalGroupId, createdAt])
}

model AgentActionExecution {
  id             String              @id @default(cuid())
  proposalId     String
  userId         String
  status         String
  requestPayload Json
  resultPayload  Json?
  errorMessage   String?
  idempotencyKey String
  createdAt      DateTime            @default(now())
  proposal       AgentActionProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([proposalId, idempotencyKey])
  @@index([userId, createdAt])
}

model AgentProposalGroup {
  id                 String                @id @default(cuid())
  threadId           String
  runId              String
  userId             String
  reviewSnapshotId   String?
  status             String                @default("pending")
  title              String
  summary            String
  preview            Json
  riskLevel          String
  strategyTemplateId String?
  strategyVersion    String?
  policyLabels       String[]              @default([])
  expiresAt          DateTime?
  executedAt         DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  thread             AgentThread           @relation(fields: [threadId], references: [id], onDelete: Cascade)
  run                AgentRun              @relation(fields: [runId], references: [id], onDelete: Cascade)
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewSnapshot     CoachingReviewSnapshot? @relation(fields: [reviewSnapshotId], references: [id], onDelete: SetNull)
  proposals          AgentActionProposal[]
  outcome            CoachingOutcome?
  recommendationFeedbacks RecommendationFeedback[]

  @@index([threadId, status, createdAt])
  @@index([userId, status, createdAt])
  @@index([reviewSnapshotId, createdAt])
}

model ToolInvocationLog {
  id           String   @id @default(cuid())
  toolName     String
  status       String
  requestData  Json
  responseData Json
  createdAt    DateTime @default(now())
}

model PlaceRecommendationSnapshot {
  id          String   @id @default(cuid())
  userId      String
  query       String
  title       String
  distanceM   Int?
  address     String
  createdAt   DateTime @default(now())
}

