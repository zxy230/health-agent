# This file is a shared template only.
# Do not use it directly as one single runtime `.env`.
#
# Copy the relevant section into:
# - `backend/.env`
# - `agent/.env`
#
# Replace all placeholder values on your own machine.

# =========================
# backend/.env
# =========================
BACKEND_PORT=3001
DATABASE_URL=postgresql://postgres:replace-me@localhost:5432/health_agent
JWT_SECRET=replace-me

# =========================
# agent/.env
# =========================
BACKEND_BASE_URL=http://localhost:3001
LLM_MODEL_ID=openrouter/free
LLM_API_KEY=replace-me
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_TIMEOUT=45
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1200
AMAP_API_KEY=

# =========================
# frontend local reference
# =========================
# These are usually only needed if your frontend setup reads local env vars.
FRONTEND_PORT=3000
AGENT_SERVICE_PORT=8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_AGENT_URL=http://localhost:8000
